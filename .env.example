# ── Database (Postgres via Supabase) ──────────────────────────
DATABASE_URL=postgresql://osint_user:osint_pass_2024@localhost:5432/osint_db

# ── Redis (Celery broker/backend) ──────────────────────────────
# Local: redis://localhost:6379/0
# Production: use your Render-managed Redis or Upstash connection string
REDIS_URL=redis://localhost:6379/0

# ── Neo4j ───────────────────────────────────────────────────────
# Local: bolt://localhost:7687
# Production: use your Neo4j AuraDB URI (starts with neo4j+s://)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_pass_2024

# ── Auth ────────────────────────────────────────────────────────
API_SECRET_KEY=f3a8c1e9b2d4f6a0c8e2b5d7f9a1c3e5b7d9f1a3c5e7b9d1f3a5c7e9b1d3f5a7
JWT_EXPIRATION=3600

# ── Server ──────────────────────────────────────────────────────
API_PORT=8000

# ── Scraping ────────────────────────────────────────────────────
USER_AGENT=OSINT-Platform/1.0
MAX_CONCURRENT_REQUESTS=10
REQUEST_DELAY=2

# ── CORS ────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173

# ── Brevo (transactional email — password reset OTP) ─────────────
BREVO_API_KEY=your-brevo-api-key-here
BREVO_SENDER_EMAIL=your-verified-sender@example.com
BREVO_SENDER_NAME=OSINT Platform